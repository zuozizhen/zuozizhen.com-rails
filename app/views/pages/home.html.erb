<% content_for :title, "" %>

<div class="sm:space-y-20 space-y-3 mb-24">
  <!-- Hero Section -->
  <section class="flex flex-col pt-20 pb-8 sm:pt-40 px-5">
    <div class="max-w-screen-lg mx-auto w-full">
      <h1 class="text-3xl font-semibold max-w-3xl">
        我是左子祯 — 设计师, 创作者。
      </h1>
      <p class="text-xl mt-3 text-neutral-500 max-w-[52rem] leading-9">
        我是一名产品设计师，乐于创作和分享，对创造充满热情，关注AI Agent、一人公司、工作流，你可以关注我的
        <%= link_to "X", "https://twitter.com/zuozizhen", target: "_blank", class: "font-medium hover:opacity-70 border-neutral-500 text-neutral-800 underline underline-offset-2" %>、<%= link_to "小红书", "https://www.xiaohongshu.com/user/profile/5c5f7e25000000001000fc79", target: "_blank", class: "font-medium hover:opacity-70 border-neutral-500 text-neutral-800 underline underline-offset-2" %>、或者下方公众号。
      </p>
      <div class="mt-12 flex items-center gap-6 flex-col md:flex-row text-center md:text-left">
        <%= image_tag "qrcode.jpg", alt: "微信公众号", class: "sm:w-32 sm:h-32 w-48 h-48 rounded-lg flex-none border border-neutral-200" %>
        <div>
          <h3 class="text-lg font-semibold mb-1">关注我的公众号</h3>
          <p class="text-neutral-500">分享 AI、一人公司相关内容</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Resources Section -->
  <section class="max-w-screen-lg mx-auto w-full px-5">
    <div class="mb-8">
      <h2 class="text-2xl font-semibold">资源</h2>
      <p class="text-neutral-500 mt-1">为设计师或创作者提供有用的资源</p>
    </div>
    <%= render "shared/resources" %>
  </section>

  <!-- Blog Section -->
  <section class="max-w-screen-lg mx-auto w-full px-5">
    <div class="mb-8">
      <h2 class="text-2xl font-semibold">文章</h2>
      <p class="text-neutral-500 mt-1">和设计、开发、创作有关的分享</p>
    </div>
    <%= render "shared/blog_list", blogs: @blogs %>
    <%= link_to "更多文章 ->", blogs_path, class: "block font-semibold mt-6 hover:opacity-70 transition" %>
  </section>
</div>
