#!/usr/bin/env bash
set -e

echo "🚀 开始部署到 VPS..."
echo ""

# 检查是否有 GitHub token
if [ -z "$GITHUB_TOKEN" ] && ! gh auth status &>/dev/null; then
  echo "❌ 错误: 需要 GitHub 认证"
  echo ""
  echo "请选择以下方式之一："
  echo "1. 运行: gh auth login"
  echo "2. 或设置环境变量: export GITHUB_TOKEN=your_token"
  echo ""
  echo "创建 token: https://github.com/settings/tokens/new"
  echo "需要权限: write:packages, read:packages"
  exit 1
fi

# 检查 master.key 是否存在
if [ ! -f config/master.key ]; then
  echo "❌ 错误: config/master.key 不存在"
  echo "这个文件包含加密凭证的密钥，部署需要它"
  exit 1
fi

echo "✅ 环境检查通过"
echo ""

# 执行部署
echo "📦 构建并部署应用..."
bin/kamal deploy

echo ""
echo "✅ 部署完成！"
echo ""
echo "🌐 访问: https://zuozizhen.com"
echo ""
echo "常用命令:"
echo "  bin/kamal app logs -f    # 查看日志"
echo "  bin/kamal app exec bash  # 进入容器"
echo "  bin/kamal console        # Rails console"
echo "  bin/kamal rollback       # 回滚到上一版本"
